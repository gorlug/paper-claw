{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "id",
    "type",
    "document_date",
    "vendor",
    "summary",
    "source_filename",
    "processed_at",
    "content_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "type": {
      "type": "string",
      "enum": [
        "invoice",
        "utility_bill",
        "bank_statement",
        "insurance_letter",
        "contract",
        "government_letter",
        "other"
      ]
    },
    "document_date": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "vendor": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "source_filename": {
      "type": "string",
      "minLength": 1
    },
    "processed_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}"
    },
    "content_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "amount": {
      "type": "number",
      "minimum": 0
    },
    "currency": {
      "type": "string",
      "minLength": 3,
      "maxLength": 3
    },
    "due_date": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "tags": {
      "type": "array",
      "items": {"type": "string"}
    },
    "language": {
      "type": "string"
    }
  }
}
